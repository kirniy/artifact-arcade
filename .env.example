# ARTIFACT Configuration

# Gemini API Key (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini image model: Nano Banana 2 Lite, Nano Banana 2, or Nano Banana Pro
GEMINI_IMAGE_MODEL=gemini-3.1-flash-lite-image
ARTIFACT_IMAGE_PROVIDER=vertex
ARTIFACT_GEMINI_PROVIDER=vertex
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_PROJECT=your_google_cloud_project
GOOGLE_CLOUD_LOCATION=global

# Environment: 'simulator' or 'hardware'
ARTIFACT_ENV=simulator

# Theme: mystical, arcade, modern, or custom theme name
ARTIFACT_THEME=mystical

# Photobooth theme: brainrot,wedding,whatsapp for Cringe Party, etc.
PHOTOBOOTH_THEME=brainrot
PHOTOBOOTH_MENU_MODES=brainrot,wedding,whatsapp

# Language: ru or en
ARTIFACT_LANGUAGE=ru

# Debug mode
ARTIFACT_DEBUG=false

# Display settings
ARTIFACT_FPS=60
ARTIFACT_FULLSCREEN=false
