# ARTIFACT Configuration

# Gemini API Key (required for AI features)
GEMINI_API_KEY=your_gemini_api_key_here

# Gemini image model: Nano Banana 2 or Nano Banana Pro
GEMINI_IMAGE_MODEL=gemini-3-pro-image-preview

# Environment: 'simulator' or 'hardware'
ARTIFACT_ENV=simulator

# Theme: mystical, arcade, modern, or custom theme name
ARTIFACT_THEME=mystical

# Photobooth theme: fiesta, feyphoria, loveintheair, etc.
PHOTOBOOTH_THEME=fiesta

# Language: ru or en
ARTIFACT_LANGUAGE=ru

# Debug mode
ARTIFACT_DEBUG=false

# Display settings
ARTIFACT_FPS=60
ARTIFACT_FULLSCREEN=false
